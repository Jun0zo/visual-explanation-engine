{
  "name": "visual-explanation-engine",
  "version": "0.1.2",
  "description": "A Codex skill that turns explanations into visual, interactive, multimodal learning experiences.",
  "license": "MIT",
  "author": "Visual Explanation Engine Contributors",
  "homepage": "https://github.com/Jun0zo/visual-explanation-engine",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jun0zo/visual-explanation-engine.git"
  },
  "bugs": {
    "url": "https://github.com/Jun0zo/visual-explanation-engine/issues"
  },
  "keywords": [
    "codex-skill",
    "visual-explanation",
    "interactive-learning",
    "diagrams",
    "education",
    "instructional-design",
    "multimodal",
    "explainers"
  ],
  "bin": {
    "visual-explanation-engine": "bin/visual-explanation-engine.js",
    "vee": "bin/visual-explanation-engine.js"
  },
  "files": [
    "bin/",
    "docs/assets/*.png",
    "docs/i18n/*.md",
    "scripts/postinstall.js",
    "skills/visual-explanation-engine/",
    "LICENSE",
    "README.md",
    "README.ko.md"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "install:skill": "node bin/visual-explanation-engine.js install --force",
    "doctor": "node bin/visual-explanation-engine.js doctor",
    "eval:research": "node scripts/research-harness.mjs",
    "report:pdf": "node scripts/build-research-report.mjs",
    "test": "node --check bin/visual-explanation-engine.js && node --check scripts/postinstall.js && node --check scripts/research-harness.mjs && node --check scripts/build-research-report.mjs",
    "pack:dry": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0"
  }
}
